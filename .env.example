# Порт MCP-сервера
MCP_PORT=3100

# Bearer-токен авторизации. Сгенерируй: node -e "console.log(crypto.randomUUID())"
# Без токена сервер работает БЕЗ авторизации — только для доверенной сети.
MCP_AUTH_TOKEN=

# Абсолютный путь к проекту, который обслуживает сервер.
# Если не задан — используется родительская папка этого сервера.
MCP_PROJECT_ROOT=
