{
  "name": "workbench-mcp",
  "version": "1.0.0",
  "description": "Remote-access MCP server: lets a Claude CLI on another machine read/write files, search code, run allow-listed commands and git over HTTP for a project.",
  "license": "MIT",
  "type": "module",
  "main": "server.mjs",
  "bin": {
    "workbench-mcp": "server.mjs"
  },
  "files": [
    "server.mjs",
    "lib/",
    "tools/",
    ".env.example"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.mjs",
    "dev": "node --watch server.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jazz-max/workbench-mcp.git"
  },
  "homepage": "https://github.com/jazz-max/workbench-mcp#readme",
  "bugs": {
    "url": "https://github.com/jazz-max/workbench-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "remote",
    "http"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "zod": "^3.25.0"
  }
}
